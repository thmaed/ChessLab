    "Faites s'affronter deux instances de Stockfish sur une série de parties pour comparer des réglages. Statistiques, écart Elo estimé avec intervalle de confiance, courbe de progression et répartition des résultats." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pit two Stockfish instances against each other over a series of games to compare settings. Statistics, estimated Elo gap with confidence interval, progression chart and result distribution."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites s'affronter deux instances de Stockfish sur une série de parties pour comparer des réglages. Statistiques, écart Elo estimé avec intervalle de confiance, courbe de progression et répartition des résultats."
          }
        }
      }
    },
