        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jusqu'à 5 s/coup — utile pour laisser respirer le moteur à Elo élevé."
          }
        }
      }
    },
    "Kádas Opening" : {
