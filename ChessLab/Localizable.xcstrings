    "Composer une position sur le plateau" : {

    },
    "Composez une position à la main sur le plateau, ou scannez-la depuis une capture d'écran, la photo d'un écran, ou un plateau réel vu du dessus. Un écran de confirmation vous laisse corriger la lecture avant de jouer ou d'analyser la position." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compose a position by hand on the board, or scan one from a screenshot, a photo of a screen, or a real board seen from above. A confirmation screen lets you correct the reading before playing or analysing the position."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Composez une position à la main sur le plateau, ou scannez-la depuis une capture d'écran, la photo d'un écran, ou un plateau réel vu du dessus. Un écran de confirmation vous laisse corriger la lecture avant de jouer ou d'analyser la position."
          }
        }
      }
    },
    "Confirmé" : {
      "extractionState" : "stale",
      "localizations" : {
