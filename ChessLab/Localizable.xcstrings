          }
        }
      }
    },
    "Construire" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Build"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construire"
          }
        }
      }
    },
    "Construisez des répertoires d'ouvertures : importez un PGN annoté ou ajoutez les coups un à un. Entraînez-les ensuite en répétition espacée — l'app vous interroge sur le coup prévu et signale quand vous vous en écartez." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Build opening repertoires: import an annotated PGN or add the moves one by one. Then train them with spaced repetition — the app quizzes you on the expected move and flags when you stray from it."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construisez des répertoires d'ouvertures : importez un PGN annoté ou ajoutez les coups un à un. Entraînez-les ensuite en répétition espacée — l'app vous interroge sur le coup prévu et signale quand vous vous en écartez."
          }
        }
      }
    },
